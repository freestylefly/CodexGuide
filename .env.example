# Public URL used in OAuth and WeChat Pay callbacks.
PUBLIC_SITE_URL=https://codexguide.ai

# Neon Postgres pooled connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Verified WeChat Official Account.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# WeChat Pay API v3 direct merchant settings.
WECHAT_PAY_MCH_ID=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WECHAT_PAY_API_V3_KEY=

# JSON object keyed by WeChat Pay platform certificate serial or public-key ID.
# Keep both old and new keys here during certificate rotation.
WECHAT_PAY_VERIFICATION_KEYS='{"SERIAL_OR_PUB_KEY_ID":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}'

# Generate three independent random values of at least 32 bytes each.
COMMUNITY_SESSION_SECRET=
COMMUNITY_BUYER_HMAC_SECRET=
ADMIN_SESSION_SECRET=

# Generate with pnpm admin:hash-password after securely exporting ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=
