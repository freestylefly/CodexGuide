# Canonical documentation and SEO origin.
PUBLIC_SITE_URL=https://codexguide.ai

# Canonical origin approved for the paid community and Alipay website payment.
# Payment pages, sessions, return_url and notify_url must all use this exact origin.
COMMUNITY_SITE_URL=https://codexguide.ai

# Keep false for the first production deployment. Turn true only after migrations,
# production credentials, a private group QR and public callback checks are ready.
COMMUNITY_PAYMENT_ENABLED=false

# Neon Postgres pooled connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Alipay website payment. Use sandbox only for local testing; production values must
# come from one published Alipay application and must never be committed.
ALIPAY_ENV=production
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SELLER_ID=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_ENABLED=true

# The legacy WeChat Pay backend is retained but hidden and disabled by default.
WECHAT_PAYMENT_ENABLED=false

# Generate three independent random values of at least 32 bytes each.
COMMUNITY_SESSION_SECRET=
COMMUNITY_BUYER_HMAC_SECRET=
ADMIN_SESSION_SECRET=

# Generate with pnpm admin:hash-password after securely exporting ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=
